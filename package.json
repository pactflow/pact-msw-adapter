{
  "name": "@pactflow/pact-msw-adapter",
  "version": "4.0.1",
  "type": "module",
  "main": "./dist/pact-msw-adapter.js",
  "module": "./dist/pact-msw-adapter.js",
  "types": "./dist/src/pactMswAdapter.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pact-msw-adapter.js",
      "types": "./dist/src/pactMswAdapter.d.ts"
    }
  },
  "keywords": [
    "pact",
    "msw",
    "mock-service-work",
    "contract testing",
    "mocks",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pactflow/pact-msw-adapter.git"
  },
  "author": {
    "name": "Yousaf Nabi",
    "url": "https://you54f.com/"
  },
  "license": "MIT",
  "peerDependencies": {
    "msw": ">=2.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "build:clean": "rimraf dist && vite build",
    "test": "vitest run --reporter=verbose",
    "test:msw": "vitest run --reporter=verbose",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write --unsafe .",
    "dist:ci": "npm run build:clean && npm test",
    "release:prepare": "node scripts/release.ts prepare",
    "release:tag": "node scripts/release.ts tag",
    "example:test:cy:run": "cd examples/react && npm run test:cypress",
    "example:test:cy:open": "cd examples/react && npm run test:cypress:open",
    "example:test:unit": "cd examples/react && npm test",
    "example:test:all": "npm run example:test:unit && npm run example:test:cy",
    "example:install": "cd examples/react && npm install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@pact-foundation/pact": "^17.0.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.3.3",
    "axios": "^1.13.6",
    "msw": "2.14.6",
    "nock": "^14.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
